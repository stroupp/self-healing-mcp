{
  "name": "atr-healer",
  "description": "ATR self-healing runner and MCP server for Selenide + Cucumber regression tests.",
  "version": "0.0.1",
  "license": "MIT",
  "type": "commonjs",
  "keywords": [
    "selenide",
    "cucumber",
    "mcp",
    "test-automation",
    "self-healing",
    "copilot"
  ],
  "bin": {
    "atr": "./out/atrCli.js",
    "atr-mcp": "./out/mcpServer.js"
  },
  "files": [
    "out",
    "templates",
    "docs/atr-knowledge-architecture.md",
    "docs/copilot-customizations.md",
    "docs/atr-failure-hook.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "atr": "node ./out/atrCli.js",
    "mcp": "node ./out/mcpServer.js",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "prepack": "npm run compile",
    "pack:dry": "npm pack --dry-run"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
